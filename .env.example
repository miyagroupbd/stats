# ── Miya Stats control plane ────────────────────────────────────────────────
# PostgreSQL — the shared Miya Postgres (same instance the email pipeline uses).
DATABASE_URL=postgresql+psycopg://mgl:mgl@localhost:5433/email_pipeline

# Must match the email-pipeline APP_SECRET (decrypts per-domain SMTP secrets).
APP_SECRET=change-me-to-a-long-random-string
# JWT signing for this board's own auth. >= 32 chars.
JWT_SECRET=change-me-to-a-long-random-string-min-32

# Dashboard origins allowed to call this API.
CORS_ORIGINS=http://localhost:3000,https://stats.miyagroupbd.com

# ── N8N automation reports (off until set) ──────────────────────────────────
# N8N → Settings → API → create an API key.
N8N_BASE_URL=
N8N_API_KEY=
